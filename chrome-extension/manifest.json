{
  "manifest_version": 3,
  "name": "Analytiq Chef",
  "version": "1.2.0",
  "description": "LinkedIn campaign messaging: sequences with _FN_ placeholders and contact lists.",
  "action": {
    "default_title": "Analytiq Chef",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/in/*"],
      "js": ["lib/logger.js", "content/profile.js"],
      "run_at": "document_idle"
    }
  ]
}
